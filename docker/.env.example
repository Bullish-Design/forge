# --- Tailscale sidecar ---
TS_AUTHKEY=tskey-auth-REPLACE_ME
TS_HOSTNAME=forge
TS_EXTRA_ARGS=
FORGE_PORT=8080

# --- Forge runtime ---
# Public URL served by forge-overlay inside forge dev.
FORGE_HOST=0.0.0.0
FORGE_INTERNAL_PORT=8080

# Agent endpoint/model (passed through forge -> obsidian-agent)
AGENT_LLM_BASE_URL=http://remora-server:8000
AGENT_LLM_MODEL=openai:auto
OPENAI_API_KEY=EMPTY
ANTHROPIC_API_KEY=

# Optional: pin upstream package refs for runtime image.
FORGE_OVERLAY_REF=v0.2.1
OBSIDIAN_AGENT_REF=v0.3.1
OBSIDIAN_OPS_REF=v0.7.1
KILN_REF=v0.10.3
JJ_VERSION=0.35.0

# kiln is baked into the image from KILN_REF.

# --- Vault sync (via obsidian-agent + jj git bridge) ---
FORGE_SYNC_REMOTE_URL=https://github.com/your-org/your-vault.git
FORGE_SYNC_REMOTE_TOKEN=
FORGE_SYNC_AFTER_COMMIT=true
FORGE_SYNC_REMOTE=origin
